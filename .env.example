# Frontend
# URL backend API. Если backend недоступен или не указан —
# frontend работает offline (localStorage + IndexedDB).
VITE_API_URL=http://localhost:8000

# Backend
# SQLite для локальной разработки, PostgreSQL для production.
# DATABASE_URL=sqlite:///./professyans.db
# DATABASE_URL=postgresql+psycopg://professyans:professyans@localhost:5433/professyans

# CORS — список разрешённых origin'ов для frontend (через запятую).
# Используется переменная CORS_ALLOW_ORIGINS в backend/app/config.py.
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080

# Logging
# LOG_LEVEL=info
